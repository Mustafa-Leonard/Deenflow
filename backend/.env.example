# ============================================================
#  DeenFlow — Production Environment Variables Template
#  ============================================================
#  RULES:
#   1. NEVER commit a filled-in copy of this file to Git.
#   2. In production: inject these from your secrets manager
#      (AWS Secrets Manager / GCP Secret Manager / Vault / Doppler).
#   3. Rotate secrets at least every 90 days.
#   4. Each deployment environment (staging, prod) uses different values.
# ============================================================

# ─── Django Core ────────────────────────────────────────────
DEBUG=False
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=REPLACE_WITH_50_CHAR_RANDOM_STRING
DJANGO_ALLOWED_HOSTS=api.deenflow.com,deenflow.com

# ─── JWT ────────────────────────────────────────────────────
# Use a DIFFERENT key from SECRET_KEY
JWT_SECRET_KEY=REPLACE_WITH_ANOTHER_64_CHAR_RANDOM_STRING
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# ─── Database — Primary (Writes) ────────────────────────────
# Format: postgresql://ROLE:PASSWORD@HOST:PORT/DBNAME?sslmode=require
# HOST points to PgBouncer, NOT directly to Postgres
DATABASE_URL=postgresql://deenflow_app:STRONG_PASS@pgbouncer:6432/deenflow_prod?sslmode=require

# ─── Database — Read Replica(s) ─────────────────────────────
DATABASE_REPLICA_URL=postgresql://deenflow_readonly:STRONG_PASS@pgbouncer-replica:6432/deenflow_prod?sslmode=require

# ─── Database TLS settings ──────────────────────────────────
DB_SSLMODE=require
# Path inside the container to the server CA cert (for mutual TLS verification)
DB_SSLROOTCERT=/run/secrets/postgres_ca.crt

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://:REDIS_STRONG_PASS@redis:6379/0

# ─── CORS ───────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://deenflow.com,https://app.deenflow.com

# ─── Rate Limiting ──────────────────────────────────────────
DRF_ANON_RATE=20/min
DRF_USER_RATE=120/min

# ─── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=REPLACE_WITH_OPENAI_KEY

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Sentry (optional but recommended for production) ───────
SENTRY_DSN=https://YOUR_KEY@oXXXX.ingest.sentry.io/PROJECT_ID
